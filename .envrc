# Load the pinned toolchain (just, ast-grep, buf, gitleaks, release-plz, rust)
# onto PATH on entry, so `just`/`cargo`/etc. resolve to the versions in
# .mise.toml without manual activation. Requires `direnv allow` once.
watch_file .mise.toml rust-toolchain.toml
eval "$(mise env)"

# This repo is pushed via the `tsouza` GitHub identity: the git remote uses the
# github.com-tsouza SSH alias, so pushes authenticate as tsouza regardless of
# which account `gh` has active. See git config remote.origin.url.
